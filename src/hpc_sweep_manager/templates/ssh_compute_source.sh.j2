#!/bin/bash
# Push-model SSHComputeSource wrapper for {{ job_name }} (job_id={{ job_id }}).
# Runs on the remote host inside the rsync'd code dir.
set -e

{% if cuda_visible_devices is not none %}
export CUDA_VISIBLE_DEVICES={{ cuda_visible_devices }}
{% endif %}
{% include "_conda_init.sh.j2" %}
{% for mod in modules %}
module load {{ mod }} 2>/dev/null || echo "warning: module load {{ mod }} failed" >&2
{% endfor %}
{% for line in pre_script %}
{{ line }}
{% endfor %}

cd {{ remote_code_dir }}

mkdir -p {{ remote_task_dir }}
{
    echo "Job ID: {{ job_id }}"
    echo "Task: {{ job_name }}"
    echo "Node: $(hostname)"
    echo "Parameters: {{ params_hydra }}"
    echo "CUDA_VISIBLE_DEVICES: ${CUDA_VISIBLE_DEVICES:-<unset>}"
    echo "Started: $(date)"
} > {{ remote_task_dir }}/task_info.txt

COMMAND="{{ run_prefix }} {{ script_path }} {{ params_hydra }} wandb.group={{ wandb_group }} output.dir={{ remote_task_dir }}"
echo "$COMMAND" > {{ remote_task_dir }}/command.txt
echo "Executing: $COMMAND"

if eval "$COMMAND"; then
    {
        echo "Completed: $(date)"
        echo "Status: SUCCESS"
    } >> {{ remote_task_dir }}/task_info.txt
else
    exit_code=$?
    {
        echo "Failed: $(date)"
        echo "Status: FAILED"
        echo "Exit Code: $exit_code"
    } >> {{ remote_task_dir }}/task_info.txt
    exit $exit_code
fi
