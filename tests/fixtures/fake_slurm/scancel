#!/usr/bin/env python3
"""Fake scancel: marks the targeted job as CANCELLED in jobs.jsonl."""

from __future__ import annotations

import json
import os
import sys


def main() -> int:
    state_dir = os.environ.get("HSM_FAKE_STATE_DIR")
    if not state_dir:
        print("HSM_FAKE_STATE_DIR not set", file=sys.stderr)
        return 1

    if len(sys.argv) < 2:
        print("scancel: missing job id", file=sys.stderr)
        return 1
    target = sys.argv[1]

    state_path = os.path.join(state_dir, "jobs.jsonl")
    if not os.path.exists(state_path):
        return 0  # Nothing to cancel; treat as no-op success.

    jobs: list[dict] = []
    with open(state_path) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            jobs.append(json.loads(line))

    found = False
    for j in jobs:
        if j["id"] == target:
            j["state"] = "CANCELLED"
            found = True

    with open(state_path, "w") as f:
        for j in jobs:
            f.write(json.dumps(j) + "\n")

    return 0 if found else 1


if __name__ == "__main__":
    sys.exit(main())
